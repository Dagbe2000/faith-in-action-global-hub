# Sanity CMS Configuration
# Get these from https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Sanity API Token (for write access / Studio)
# Create at: https://www.sanity.io/manage → your project → API → Tokens
SANITY_API_TOKEN=your_sanity_api_token_here

# Sanity Webhook Secret (for revalidation)
SANITY_WEBHOOK_SECRET=your_webhook_secret_here

# Contact Form (optional - e.g. Resend, SendGrid, or Nodemailer)
CONTACT_EMAIL_TO=info@faithinaction.org
RESEND_API_KEY=your_resend_api_key_here

# Site URL
NEXT_PUBLIC_SITE_URL=https://faithinactionglobalhub.org
